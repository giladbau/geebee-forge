---
import { ClientRouter } from 'astro:transitions';
import GlobalNav from '../components/GlobalNav.astro';

interface Props {
	title: string;
}

const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1" />
	<title>{title}</title>
	<ClientRouter />
</head>
<body>
	<GlobalNav />
	<slot />
</body>
</html>

<style is:global>
	body {
		margin: 0;
		padding: 0;
		background: #0a0a0a;
		color: #e0e0e0;
		font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
	}
	* { box-sizing: border-box; }
	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0,0,0,0);
		white-space: nowrap;
		border: 0;
	}
</style>
