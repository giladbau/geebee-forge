---
const pathname = Astro.url.pathname;

const demos = [
  { href: '/unicorn-farm', label: 'Unicorn Farm' },
  { href: '/growing-tree', label: 'Growing Tree' },
  { href: '/receipt', label: 'Receipt' },
  { href: '/digest', label: 'Digest' },
  { href: '/wandering-inn', label: 'Wandering Inn' },
];

const archive = [
  { href: '/alerts', label: 'Alerts' },
  { href: '/constellation', label: 'Constellation' },
];
---

<nav class="global-nav">
  <div class="left">
    {pathname !== '/' && (
      <a href="/" class="back-btn" aria-label="Back to home">&#8592;</a>
    )}
    <a href="/" class:list={['brand', { active: pathname === '/' }]}>
      <span class="brand-glyph">⬡</span>
      <span class="brand-name">GeeBee Forge</span>
    </a>
  </div>

  <div class="nav-links">
    <div class="demo-links" aria-label="Primary demos">
      {demos.map(({ href, label }) => (
        <a
          href={href}
          class:list={['demo-link', { active: pathname.startsWith(href) }]}
        >
          {label}
        </a>
      ))}
    </div>

    <div class="archive-links" aria-label="Archive">
      <span class="archive-label">Archive</span>
      {archive.map(({ href, label }) => (
        <a
          href={href}
          class:list={['demo-link', 'archive-link', { active: pathname.startsWith(href) }]}
        >
          {label}
        </a>
      ))}
    </div>
  </div>
</nav>

<style>
  .global-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 1.25rem;
    background: rgba(10, 10, 10, 0.75);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .left {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .back-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 6px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: #888;
    text-decoration: none;
    font-size: 1rem;
    transition: color 0.2s, background 0.2s, border-color 0.2s;
  }

  .back-btn:hover {
    color: #e0e0e0;
    background: rgba(255, 255, 255, 0.07);
    border-color: rgba(255, 255, 255, 0.2);
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    text-decoration: none;
    color: #888;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    transition: color 0.2s;
  }

  .brand:hover,
  .brand.active {
    color: #e0e0e0;
  }

  .brand-glyph {
    font-size: 1rem;
    color: #6ba3ff;
  }

  .nav-links,
  .demo-links,
  .archive-links {
    display: flex;
    align-items: center;
  }

  .nav-links {
    gap: 0.85rem;
  }

  .demo-links,
  .archive-links {
    gap: 0.25rem;
  }

  .archive-links {
    padding-left: 0.85rem;
    border-left: 1px solid rgba(255, 255, 255, 0.08);
  }

  .archive-label {
    color: #555;
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
  }

  .demo-link {
    text-decoration: none;
    color: #666;
    font-size: 0.8rem;
    font-weight: 500;
    padding: 0.3rem 0.7rem;
    border-radius: 6px;
    border: 1px solid transparent;
    transition: color 0.2s, background 0.2s, border-color 0.2s;
  }

  .demo-link:hover {
    color: #e0e0e0;
    background: rgba(255, 255, 255, 0.05);
  }

  .demo-link.active {
    color: #6ba3ff;
    background: rgba(107, 163, 255, 0.08);
    border-color: rgba(107, 163, 255, 0.2);
  }

  .archive-link {
    color: #555;
  }

  @media (max-width: 500px) {
    .brand-name {
      display: none;
    }

    .nav-links {
      gap: 0.35rem;
    }

    .archive-links {
      padding-left: 0.35rem;
    }

    .archive-label {
      display: none;
    }

    .demo-link {
      padding: 0.3rem 0.5rem;
      font-size: 0.75rem;
    }
  }
</style>
