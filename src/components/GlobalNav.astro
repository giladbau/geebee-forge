---
const pathname = Astro.url.pathname;

const demos = [
  { href: '/constellation', label: 'Constellation' },
  { href: '/unicorn-farm', label: 'Unicorn Farm' },
  { href: '/digest', label: 'Digest' },
  { href: '/alerts', label: 'Alerts' },
];
---

<nav class="global-nav">
  <a href="/" class:list={['brand', { active: pathname === '/' }]}>
    <span class="brand-glyph">⬡</span>
    <span class="brand-name">GeeBee Forge</span>
  </a>

  <div class="demo-links">
    {demos.map(({ href, label }) => (
      <a
        href={href}
        class:list={['demo-link', { active: pathname.startsWith(href) }]}
      >
        {label}
      </a>
    ))}
  </div>
</nav>

<style>
  .global-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 1.25rem;
    background: rgba(10, 10, 10, 0.75);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    text-decoration: none;
    color: #888;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    transition: color 0.2s;
  }

  .brand:hover,
  .brand.active {
    color: #e0e0e0;
  }

  .brand-glyph {
    font-size: 1rem;
    color: #6ba3ff;
  }

  .demo-links {
    display: flex;
    gap: 0.25rem;
  }

  .demo-link {
    text-decoration: none;
    color: #666;
    font-size: 0.8rem;
    font-weight: 500;
    padding: 0.3rem 0.7rem;
    border-radius: 6px;
    border: 1px solid transparent;
    transition: color 0.2s, background 0.2s, border-color 0.2s;
  }

  .demo-link:hover {
    color: #e0e0e0;
    background: rgba(255, 255, 255, 0.05);
  }

  .demo-link.active {
    color: #6ba3ff;
    background: rgba(107, 163, 255, 0.08);
    border-color: rgba(107, 163, 255, 0.2);
  }

  @media (max-width: 500px) {
    .brand-name {
      display: none;
    }

    .demo-link {
      padding: 0.3rem 0.5rem;
      font-size: 0.75rem;
    }
  }
</style>
