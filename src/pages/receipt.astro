---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Receipt | GeeBee Forge">
  <main class="receipt-page">
    <div id="receipt-container">
      <div id="wrap">
        <canvas id="glcanvas"></canvas>
        <div id="grab-indicator"></div>
      </div>
      <div id="instruction">Grab and drag the receipt</div>
    </div>
  </main>
</BaseLayout>

<style>
  :global(body) {
    background: #e5e5e5;
  }

  .receipt-page {
    width: 100%;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #receipt-container {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  #wrap {
    position: relative;
  }

  canvas {
    display: block;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
    cursor: grab;
    border-radius: 4px;
    touch-action: none;
    -webkit-user-select: none;
    user-select: none;
    -webkit-touch-callout: none;
  }

  canvas:active {
    cursor: grabbing;
  }

  #grab-indicator {
    position: absolute;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: rgba(0, 150, 255, 0.22);
    border: 2px solid rgba(0, 150, 255, 0.7);
    pointer-events: none;
    display: none;
    transform: translate(-50%, -50%);
    z-index: 10;
  }

  #instruction {
    margin-top: 16px;
    color: #999;
    font-size: 14px;
    letter-spacing: 0.5px;
    user-select: none;
    pointer-events: none;
  }
</style>

<script is:inline>
(function () {
  const canvas = document.getElementById('glcanvas');
  const indicator = document.getElementById('grab-indicator');
  const W = Math.min(window.innerWidth - 40, 640);
  const H = Math.min(window.innerHeight - 120, 800);
  canvas.width = W;
  canvas.height = H;
  canvas.style.width = W + 'px';
  canvas.style.height = H + 'px';

  const gl = canvas.getContext('webgl', { alpha: false, antialias: true });
  if (!gl) { alert('WebGL not supported'); return; }

  function createShader(type, src) {
    const s = gl.createShader(type);
    gl.shaderSource(s, src);
    gl.compileShader(s);
    if (!gl.getShaderParameter(s, gl.COMPILE_STATUS)) console.error(gl.getShaderInfoLog(s));
    return s;
  }
  function createProgram(vsSrc, fsSrc) {
    const p = gl.createProgram();
    gl.attachShader(p, createShader(gl.VERTEX_SHADER, vsSrc));
    gl.attachShader(p, createShader(gl.FRAGMENT_SHADER, fsSrc));
    gl.linkProgram(p);
    if (!gl.getProgramParameter(p, gl.LINK_STATUS)) console.error(gl.getProgramInfoLog(p));
    return p;
  }

  function createReceiptTexture() {
    const c = document.createElement('canvas');
    c.width = 512;
    c.height = 1024;
    const ctx = c.getContext('2d');
    ctx.fillStyle = '#fdfbf7';
    ctx.fillRect(0, 0, 512, 1024);
    ctx.fillStyle = '#222';
    ctx.textBaseline = 'top';
    let y = 60;
    ctx.font = 'bold 36px monospace';
    ctx.textAlign = 'center';
    ctx.fillText('THE FLORNRM SHOP', 256, y);
    y += 50;
    ctx.font = '20px monospace';
    ctx.fillText('42 Mesh Lane, WebGL City', 256, y);
    y += 30;
    ctx.fillText('Tel: (555) 042-1337', 256, y);
    y += 50;
    ctx.font = '18px monospace';
    ctx.textAlign = 'left';
    ctx.fillText('Date: 2026-02-23  14:17', 40, y);
    y += 28;
    ctx.fillText('Order: #00382', 40, y);
    y += 30;
    ctx.strokeStyle = '#222';
    ctx.lineWidth = 1;
    ctx.setLineDash([8, 6]);
    ctx.beginPath();
    ctx.moveTo(40, y);
    ctx.lineTo(472, y);
    ctx.stroke();
    const items = [
      ['Vertex Shader', '$4.20'],
      ['Fragment Shader', '$3.50'],
      ['Normal Map', '$2.80'],
      ['UV Unwrap', '$1.50'],
      ['Cloth Simulation', '$6.00'],
    ];
    y += 30;
    ctx.font = '18px monospace';
    items.forEach(([n, pr]) => {
      ctx.textAlign = 'left';
      ctx.fillText(n, 40, y);
      ctx.textAlign = 'right';
      ctx.fillText(pr, 472, y);
      y += 28;
    });
    y += 10;
    ctx.setLineDash([8, 6]);
    ctx.beginPath();
    ctx.moveTo(40, y);
    ctx.lineTo(472, y);
    ctx.stroke();
    y += 30;
    ctx.font = '18px monospace';
    ctx.textAlign = 'left';
    ctx.fillText('Subtotal', 40, y);
    ctx.textAlign = 'right';
    ctx.fillText('$18.00', 472, y);
    y += 28;
    ctx.textAlign = 'left';
    ctx.fillText('Tax (8%)', 40, y);
    ctx.textAlign = 'right';
    ctx.fillText('$1.44', 472, y);
    y += 30;
    ctx.setLineDash([]);
    ctx.lineWidth = 3;
    ctx.beginPath();
    ctx.moveTo(40, y);
    ctx.lineTo(472, y);
    ctx.stroke();
    y += 30;
    ctx.font = 'bold 20px monospace';
    ctx.textAlign = 'left';
    ctx.fillText('TOTAL', 40, y);
    ctx.textAlign = 'right';
    ctx.fillText('$19.44', 472, y);
    y += 50;
    ctx.font = '18px monospace';
    ctx.textAlign = 'center';
    ctx.fillText('Thank you for visiting!', 256, y);
    y += 28;
    ctx.font = '14px monospace';
    ctx.fillText('github.com/giladbau', 256, y);

    const tex = gl.createTexture();
    gl.bindTexture(gl.TEXTURE_2D, tex);
    gl.pixelStorei(gl.UNPACK_FLIP_Y_WEBGL, true);
    gl.texImage2D(gl.TEXTURE_2D, 0, gl.RGBA, gl.RGBA, gl.UNSIGNED_BYTE, c);
    gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MIN_FILTER, gl.LINEAR);
    gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MAG_FILTER, gl.LINEAR);
    gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_S, gl.CLAMP_TO_EDGE);
    gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_T, gl.CLAMP_TO_EDGE);
    return tex;
  }
  const texture = createReceiptTexture();

  const cols = 26, rows = 51;
  const width = 3, height = 6;
  const wr = width / (cols - 1), hr = height / (rows - 1);
  const particles = [];
  for (let j = 0; j < rows; j++) {
    for (let i = 0; i < cols; i++) {
      particles.push({
        x: -width / 2 + i * wr,
        y: height / 2 - j * hr,
        z: (Math.random() - 0.5) * 0.03,
        ox: -width / 2 + i * wr,
        oy: height / 2 - j * hr,
        oz: (Math.random() - 0.5) * 0.03,
        pinned: j === 0,
      });
    }
  }
  const constraints = [];
  function addConstraint(i1, j1, i2, j2) {
    const a = j1 * cols + i1;
    const b = j2 * cols + i2;
    const dx = particles[b].x - particles[a].x;
    const dy = particles[b].y - particles[a].y;
    const dz = particles[b].z - particles[a].z;
    constraints.push({ a, b, rest: Math.sqrt(dx * dx + dy * dy + dz * dz) });
  }
  for (let j = 0; j < rows; j++) {
    for (let i = 0; i < cols; i++) {
      if (i < cols - 1) addConstraint(i, j, i + 1, j);
      if (j < rows - 1) addConstraint(i, j, i, j + 1);
      if (i < cols - 1 && j < rows - 1) {
        addConstraint(i, j, i + 1, j + 1);
        addConstraint(i + 1, j, i, j + 1);
      }
      if (i < cols - 2) addConstraint(i, j, i + 2, j);
      if (j < rows - 2) addConstraint(i, j, i, j + 2);
    }
  }

  const positions = new Float32Array(particles.length * 3);
  const normals = new Float32Array(particles.length * 3);
  const texCoords = new Float32Array(particles.length * 2);
  const shadowPositions = new Float32Array(particles.length * 3);
  for (let j = 0; j < rows; j++) {
    for (let i = 0; i < cols; i++) {
      const idx = j * cols + i;
      texCoords[idx * 2] = i / (cols - 1);
      texCoords[idx * 2 + 1] = j / (rows - 1);
    }
  }
  const indices = [];
  for (let j = 0; j < rows - 1; j++) {
    for (let i = 0; i < cols - 1; i++) {
      const a = j * cols + i;
      const b = a + 1;
      const c = a + cols;
      const d = c + 1;
      indices.push(a, c, b, b, c, d);
    }
  }
  const indexCount = indices.length;

  const posBuf = gl.createBuffer();
  const normBuf = gl.createBuffer();
  const texBuf = gl.createBuffer();
  const indBuf = gl.createBuffer();
  gl.bindBuffer(gl.ELEMENT_ARRAY_BUFFER, indBuf);
  gl.bufferData(gl.ELEMENT_ARRAY_BUFFER, new Uint16Array(indices), gl.STATIC_DRAW);
  gl.bindBuffer(gl.ARRAY_BUFFER, texBuf);
  gl.bufferData(gl.ARRAY_BUFFER, texCoords, gl.STATIC_DRAW);

  const shadowPosBuf = gl.createBuffer();

  const groundPos = new Float32Array([-12, -4.2, -12, 12, -4.2, -12, -12, -4.2, 12, 12, -4.2, 12]);
  const groundInd = new Uint16Array([0, 2, 1, 1, 2, 3]);
  const groundPosBuf = gl.createBuffer();
  const groundIndBuf = gl.createBuffer();
  gl.bindBuffer(gl.ARRAY_BUFFER, groundPosBuf);
  gl.bufferData(gl.ARRAY_BUFFER, groundPos, gl.STATIC_DRAW);
  gl.bindBuffer(gl.ELEMENT_ARRAY_BUFFER, groundIndBuf);
  gl.bufferData(gl.ELEMENT_ARRAY_BUFFER, groundInd, gl.STATIC_DRAW);

  function setIdentity(m) { for (let i = 0; i < 16; i++) m[i] = (i % 5 === 0) ? 1 : 0; }
  function mat4Perspective(m, fovy, aspect, near, far) {
    const f = 1 / Math.tan(fovy / 2), nf = 1 / (near - far);
    m[0] = f / aspect; m[1] = 0; m[2] = 0; m[3] = 0;
    m[4] = 0; m[5] = f; m[6] = 0; m[7] = 0;
    m[8] = 0; m[9] = 0; m[10] = (far + near) * nf; m[11] = -1;
    m[12] = 0; m[13] = 0; m[14] = 2 * far * near * nf; m[15] = 0;
  }
  function mat4LookAt(m, eye, center, up) {
    let zx = eye[0] - center[0], zy = eye[1] - center[1], zz = eye[2] - center[2];
    let zlen = Math.sqrt(zx * zx + zy * zy + zz * zz); zx /= zlen; zy /= zlen; zz /= zlen;
    let xx = up[1] * zz - up[2] * zy, xy = up[2] * zx - up[0] * zz, xz = up[0] * zy - up[1] * zx;
    let xlen = Math.sqrt(xx * xx + xy * xy + xz * xz); xx /= xlen; xy /= xlen; xz /= xlen;
    let yx = zy * xz - zz * xy, yy = zz * xx - zx * xz, yz = zx * xy - zy * xx;
    m[0] = xx; m[1] = yx; m[2] = zx; m[3] = 0;
    m[4] = xy; m[5] = yy; m[6] = zy; m[7] = 0;
    m[8] = xz; m[9] = yz; m[10] = zz; m[11] = 0;
    m[12] = -(xx * eye[0] + xy * eye[1] + xz * eye[2]);
    m[13] = -(yx * eye[0] + yy * eye[1] + yz * eye[2]);
    m[14] = -(zx * eye[0] + zy * eye[1] + zz * eye[2]);
    m[15] = 1;
  }
  function mat4Multiply(out, a, b) {
    const r = new Float32Array(16);
    for (let col = 0; col < 4; col++) {
      for (let row = 0; row < 4; row++) {
        let s = 0;
        for (let k = 0; k < 4; k++) s += a[k * 4 + row] * b[col * 4 + k];
        r[col * 4 + row] = s;
      }
    }
    for (let i = 0; i < 16; i++) out[i] = r[i];
  }
  function mat4Invert(out, a) {
    const m = new Float32Array(16), inv = new Float32Array(16);
    for (let i = 0; i < 16; i++) { m[i] = a[i]; inv[i] = (i % 5 === 0) ? 1 : 0; }
    for (let col = 0; col < 4; col++) {
      let pivot = col, max = Math.abs(m[col * 4 + col]);
      for (let row = col + 1; row < 4; row++) { const v = Math.abs(m[col * 4 + row]); if (v > max) { max = v; pivot = row; } }
      if (max < 1e-10) { setIdentity(out); return; }
      if (pivot !== col) {
        for (let k = 0; k < 4; k++) {
          const i1 = k * 4 + pivot, i2 = k * 4 + col;
          let t = m[i1]; m[i1] = m[i2]; m[i2] = t;
          t = inv[i1]; inv[i1] = inv[i2]; inv[i2] = t;
        }
      }
      const piv = m[col * 4 + col], ip = 1.0 / piv;
      for (let k = 0; k < 4; k++) { m[k * 4 + col] *= ip; inv[k * 4 + col] *= ip; }
      for (let row = 0; row < 4; row++) {
        if (row === col) continue;
        const f = m[col * 4 + row];
        if (Math.abs(f) > 0) {
          for (let k = 0; k < 4; k++) {
            m[k * 4 + row] -= f * m[k * 4 + col];
            inv[k * 4 + row] -= f * inv[k * 4 + col];
          }
        }
      }
    }
    for (let i = 0; i < 16; i++) out[i] = inv[i];
  }

  const projection = new Float32Array(16);
  const view = new Float32Array(16);
  const pv = new Float32Array(16);
  const invPV = new Float32Array(16);
  mat4Perspective(projection, Math.PI / 4, canvas.width / canvas.height, 0.1, 100);
  mat4LookAt(view, [0, -1, 12], [0, -1, 0], [0, 1, 0]);
  mat4Multiply(pv, projection, view);
  mat4Invert(invPV, pv);

  const receiptProg = createProgram(
    `attribute vec3 aPosition; attribute vec3 aNormal; attribute vec2 aTexCoord;
     uniform mat4 uProjectionMatrix; uniform mat4 uModelViewMatrix; uniform mat3 uNormalMatrix;
     varying vec3 vNormal; varying vec3 vPosition; varying vec2 vTexCoord;
     void main(){ vec4 mv=uModelViewMatrix*vec4(aPosition,1.0); vPosition=mv.xyz; vNormal=uNormalMatrix*aNormal; vTexCoord=aTexCoord; gl_Position=uProjectionMatrix*mv; }`,
    `precision mediump float;
     varying vec3 vNormal; varying vec3 vPosition; varying vec2 vTexCoord;
     uniform vec3 uLightDir; uniform vec3 uAmbientColor; uniform vec3 uDiffuseColor; uniform sampler2D uTexture;
     void main(){ vec3 normal=normalize(vNormal); if(!gl_FrontFacing) normal=-normal; float diff=max(dot(normal,normalize(uLightDir)),0.0); vec4 tex=texture2D(uTexture,vTexCoord); vec3 c=tex.rgb*(uAmbientColor+uDiffuseColor*diff); gl_FragColor=vec4(c,1.0); }`
  );
  const shadowProg = createProgram(
    `attribute vec3 aPosition; uniform mat4 uMVP; void main(){ gl_Position=uMVP*vec4(aPosition,1.0); }`,
    `precision mediump float; void main(){ gl_FragColor=vec4(0.0,0.0,0.0,0.22); }`
  );
  const groundProg = createProgram(
    `attribute vec3 aPosition; uniform mat4 uMVP; void main(){ gl_Position=uMVP*vec4(aPosition,1.0); }`,
    `precision mediump float; uniform vec3 uColor; void main(){ gl_FragColor=vec4(uColor,1.0); }`
  );

  const rp = {
    aPos: gl.getAttribLocation(receiptProg, 'aPosition'),
    aNorm: gl.getAttribLocation(receiptProg, 'aNormal'),
    aTex: gl.getAttribLocation(receiptProg, 'aTexCoord'),
    uProj: gl.getUniformLocation(receiptProg, 'uProjectionMatrix'),
    uMV: gl.getUniformLocation(receiptProg, 'uModelViewMatrix'),
    uNormMat: gl.getUniformLocation(receiptProg, 'uNormalMatrix'),
    uLight: gl.getUniformLocation(receiptProg, 'uLightDir'),
    uAmb: gl.getUniformLocation(receiptProg, 'uAmbientColor'),
    uDiff: gl.getUniformLocation(receiptProg, 'uDiffuseColor'),
    uTex: gl.getUniformLocation(receiptProg, 'uTexture'),
  };
  const sp = {
    aPos: gl.getAttribLocation(shadowProg, 'aPosition'),
    uMVP: gl.getUniformLocation(shadowProg, 'uMVP'),
  };
  const gp = {
    aPos: gl.getAttribLocation(groundProg, 'aPosition'),
    uMVP: gl.getUniformLocation(groundProg, 'uMVP'),
    uColor: gl.getUniformLocation(groundProg, 'uColor'),
  };

  let grabbedIndex = -1;
  let grabPlaneN = [0, 0, 0];
  let grabPlaneP = [0, 0, 0];

  function getRay(mx, my) {
    const x = (mx / canvas.width) * 2 - 1;
    const y = -(my / canvas.height) * 2 + 1;
    const t = (v) => {
      const o = [0, 0, 0, 0];
      for (let i = 0; i < 4; i++) o[i] = invPV[i * 4 + 0] * v[0] + invPV[i * 4 + 1] * v[1] + invPV[i * 4 + 2] * v[2] + invPV[i * 4 + 3] * v[3];
      return o;
    };
    const a = t([x, y, -1, 1]), b = t([x, y, 1, 1]);
    const o = [a[0] / a[3], a[1] / a[3], a[2] / a[3]];
    const tx = b[0] / b[3] - o[0], ty = b[1] / b[3] - o[1], tz = b[2] / b[3] - o[2];
    const len = Math.sqrt(tx * tx + ty * ty + tz * tz);
    return { origin: o, dir: [tx / len, ty / len, tz / len] };
  }

  canvas.addEventListener('pointerdown', (e) => {
    const rect = canvas.getBoundingClientRect();
    const mx = e.clientX - rect.left;
    const my = e.clientY - rect.top;
    let best = -1, bestD = Infinity;
    const px = (mx / canvas.width) * 2 - 1, py = -(my / canvas.height) * 2 + 1;
    for (let i = 0; i < particles.length; i++) {
      const p = particles[i];
      const cx = pv[0] * p.x + pv[4] * p.y + pv[8] * p.z + pv[12];
      const cy = pv[1] * p.x + pv[5] * p.y + pv[9] * p.z + pv[13];
      const cw = pv[3] * p.x + pv[7] * p.y + pv[11] * p.z + pv[15];
      const ndcx = cx / cw, ndcy = cy / cw;
      const d = (ndcx - px) * (ndcx - px) + (ndcy - py) * (ndcy - py);
      if (d < bestD) { bestD = d; best = i; }
    }
    if (best !== -1 && bestD < 0.04) {
      grabbedIndex = best;
      const p = particles[best];
      grabPlaneP = [p.x, p.y, p.z];
      grabPlaneN = [0, 0, -1];
      canvas.setPointerCapture(e.pointerId);
    }
  });
  canvas.addEventListener('pointermove', (e) => {
    if (grabbedIndex === -1) return;
    const rect = canvas.getBoundingClientRect();
    const mx = e.clientX - rect.left;
    const my = e.clientY - rect.top;
    const ray = getRay(mx, my);
    const denom = ray.dir[0] * grabPlaneN[0] + ray.dir[1] * grabPlaneN[1] + ray.dir[2] * grabPlaneN[2];
    if (Math.abs(denom) < 1e-6) return;
    const t = ((grabPlaneP[0] - ray.origin[0]) * grabPlaneN[0] + (grabPlaneP[1] - ray.origin[1]) * grabPlaneN[1] + (grabPlaneP[2] - ray.origin[2]) * grabPlaneN[2]) / denom;
    const hx = ray.origin[0] + ray.dir[0] * t, hy = ray.origin[1] + ray.dir[1] * t, hz = ray.origin[2] + ray.dir[2] * t;
    const p = particles[grabbedIndex];
    p.x = hx; p.y = hy; p.z = hz; p.ox = hx; p.oy = hy; p.oz = hz;
  });
  canvas.addEventListener('pointerup', (e) => {
    grabbedIndex = -1;
    canvas.releasePointerCapture(e.pointerId);
  });

  function simulate() {
    const dt = 0.016, gravity = -9.8, damping = 0.985;
    for (let p of particles) {
      if (p.pinned) continue;
      const vx = (p.x - p.ox) * damping, vy = (p.y - p.oy) * damping, vz = (p.z - p.oz) * damping;
      p.ox = p.x; p.oy = p.y; p.oz = p.z;
      p.x += vx; p.y += vy + gravity * dt * dt; p.z += vz;
    }
    for (let iter = 0; iter < 10; iter++) {
      for (let c of constraints) {
        const p1 = particles[c.a], p2 = particles[c.b];
        let dx = p2.x - p1.x, dy = p2.y - p1.y, dz = p2.z - p1.z;
        const dist = Math.sqrt(dx * dx + dy * dy + dz * dz) || 1e-8;
        const diff = (dist - c.rest) / dist * 0.5;
        if (!p1.pinned) { p1.x += dx * diff; p1.y += dy * diff; p1.z += dz * diff; }
        if (!p2.pinned) { p2.x -= dx * diff; p2.y -= dy * diff; p2.z -= dz * diff; }
      }
    }
  }

  function updateGeometry() {
    for (let i = 0; i < particles.length; i++) {
      positions[i * 3] = particles[i].x;
      positions[i * 3 + 1] = particles[i].y;
      positions[i * 3 + 2] = particles[i].z;
    }
    for (let i = 0; i < normals.length; i++) normals[i] = 0;
    for (let j = 0; j < rows - 1; j++) {
      for (let i = 0; i < cols - 1; i++) {
        const i00 = j * cols + i, i10 = i00 + 1, i01 = i00 + cols, i11 = i01 + 1;
        let e1x = positions[i10 * 3] - positions[i00 * 3], e1y = positions[i10 * 3 + 1] - positions[i00 * 3 + 1], e1z = positions[i10 * 3 + 2] - positions[i00 * 3 + 2];
        let e2x = positions[i01 * 3] - positions[i00 * 3], e2y = positions[i01 * 3 + 1] - positions[i00 * 3 + 1], e2z = positions[i01 * 3 + 2] - positions[i00 * 3 + 2];
        let nx = e2y * e1z - e2z * e1y, ny = e2z * e1x - e2x * e1z, nz = e2x * e1y - e2y * e1x;
        normals[i00 * 3] += nx; normals[i00 * 3 + 1] += ny; normals[i00 * 3 + 2] += nz;
        normals[i10 * 3] += nx; normals[i10 * 3 + 1] += ny; normals[i10 * 3 + 2] += nz;
        normals[i01 * 3] += nx; normals[i01 * 3 + 1] += ny; normals[i01 * 3 + 2] += nz;
        e1x = positions[i11 * 3] - positions[i10 * 3]; e1y = positions[i11 * 3 + 1] - positions[i10 * 3 + 1]; e1z = positions[i11 * 3 + 2] - positions[i10 * 3 + 2];
        e2x = positions[i01 * 3] - positions[i10 * 3]; e2y = positions[i01 * 3 + 1] - positions[i10 * 3 + 1]; e2z = positions[i01 * 3 + 2] - positions[i10 * 3 + 2];
        nx = e2y * e1z - e2z * e1y; ny = e2z * e1x - e2x * e1z; nz = e2x * e1y - e2y * e1x;
        normals[i10 * 3] += nx; normals[i10 * 3 + 1] += ny; normals[i10 * 3 + 2] += nz;
        normals[i11 * 3] += nx; normals[i11 * 3 + 1] += ny; normals[i11 * 3 + 2] += nz;
        normals[i01 * 3] += nx; normals[i01 * 3 + 1] += ny; normals[i01 * 3 + 2] += nz;
      }
    }
    for (let i = 0; i < particles.length; i++) {
      let nx = normals[i * 3], ny = normals[i * 3 + 1], nz = normals[i * 3 + 2];
      const len = Math.sqrt(nx * nx + ny * ny + nz * nz) || 1;
      normals[i * 3] = nx / len; normals[i * 3 + 1] = ny / len; normals[i * 3 + 2] = nz / len;
    }
  }

  function updateShadow() {
    const l = [0.3, 0.8, 0.5];
    const len = Math.sqrt(l[0] * l[0] + l[1] * l[1] + l[2] * l[2]);
    const lx = l[0] / len, ly = l[1] / len, lz = l[2] / len;
    for (let i = 0; i < particles.length; i++) {
      const p = particles[i];
      const t = (p.y + 4.0) / ly;
      shadowPositions[i * 3] = p.x - t * lx;
      shadowPositions[i * 3 + 1] = -4.0;
      shadowPositions[i * 3 + 2] = p.z - t * lz;
    }
  }

  function draw() {
    simulate();
    updateGeometry();
    updateShadow();

    gl.viewport(0, 0, canvas.width, canvas.height);
    gl.clearColor(0.898, 0.898, 0.898, 1.0);
    gl.clear(gl.COLOR_BUFFER_BIT | gl.DEPTH_BUFFER_BIT);
    gl.enable(gl.DEPTH_TEST);
    gl.disable(gl.CULL_FACE);

    gl.useProgram(groundProg);
    gl.uniformMatrix4fv(gp.uMVP, false, pv);
    gl.uniform3f(gp.uColor, 0.82, 0.82, 0.82);
    gl.bindBuffer(gl.ARRAY_BUFFER, groundPosBuf);
    gl.enableVertexAttribArray(gp.aPos);
    gl.vertexAttribPointer(gp.aPos, 3, gl.FLOAT, false, 0, 0);
    gl.bindBuffer(gl.ELEMENT_ARRAY_BUFFER, groundIndBuf);
    gl.drawElements(gl.TRIANGLES, 6, gl.UNSIGNED_SHORT, 0);

    gl.useProgram(shadowProg);
    gl.enable(gl.BLEND);
    gl.blendFunc(gl.SRC_ALPHA, gl.ONE_MINUS_SRC_ALPHA);
    gl.depthMask(false);
    gl.bindBuffer(gl.ARRAY_BUFFER, shadowPosBuf);
    gl.bufferData(gl.ARRAY_BUFFER, shadowPositions, gl.DYNAMIC_DRAW);
    gl.enableVertexAttribArray(sp.aPos);
    gl.vertexAttribPointer(sp.aPos, 3, gl.FLOAT, false, 0, 0);
    gl.bindBuffer(gl.ELEMENT_ARRAY_BUFFER, indBuf);
    gl.uniformMatrix4fv(sp.uMVP, false, pv);
    gl.drawElements(gl.TRIANGLES, indexCount, gl.UNSIGNED_SHORT, 0);
    gl.depthMask(true);
    gl.disable(gl.BLEND);

    gl.useProgram(receiptProg);
    gl.bindBuffer(gl.ARRAY_BUFFER, posBuf);
    gl.bufferData(gl.ARRAY_BUFFER, positions, gl.DYNAMIC_DRAW);
    gl.enableVertexAttribArray(rp.aPos);
    gl.vertexAttribPointer(rp.aPos, 3, gl.FLOAT, false, 0, 0);
    gl.bindBuffer(gl.ARRAY_BUFFER, normBuf);
    gl.bufferData(gl.ARRAY_BUFFER, normals, gl.DYNAMIC_DRAW);
    gl.enableVertexAttribArray(rp.aNorm);
    gl.vertexAttribPointer(rp.aNorm, 3, gl.FLOAT, false, 0, 0);
    gl.bindBuffer(gl.ARRAY_BUFFER, texBuf);
    gl.enableVertexAttribArray(rp.aTex);
    gl.vertexAttribPointer(rp.aTex, 2, gl.FLOAT, false, 0, 0);
    gl.bindBuffer(gl.ELEMENT_ARRAY_BUFFER, indBuf);
    gl.uniformMatrix4fv(rp.uProj, false, projection);
    gl.uniformMatrix4fv(rp.uMV, false, view);
    const nmat = new Float32Array([view[0], view[1], view[2], view[4], view[5], view[6], view[8], view[9], view[10]]);
    gl.uniformMatrix3fv(rp.uNormMat, false, nmat);
    gl.uniform3f(rp.uLight, 0.3, 0.8, 0.5);
    gl.uniform3f(rp.uAmb, 0.35, 0.35, 0.35);
    gl.uniform3f(rp.uDiff, 0.65, 0.65, 0.65);
    gl.activeTexture(gl.TEXTURE0);
    gl.bindTexture(gl.TEXTURE_2D, texture);
    gl.uniform1i(rp.uTex, 0);
    gl.drawElements(gl.TRIANGLES, indexCount, gl.UNSIGNED_SHORT, 0);

    if (grabbedIndex !== -1) {
      const p = particles[grabbedIndex];
      const cx = pv[0] * p.x + pv[4] * p.y + pv[8] * p.z + pv[12];
      const cy = pv[1] * p.x + pv[5] * p.y + pv[9] * p.z + pv[13];
      const cw = pv[3] * p.x + pv[7] * p.y + pv[11] * p.z + pv[15];
      const sx = ((cx / cw) * 0.5 + 0.5) * canvas.width;
      const sy = ((-cy / cw) * 0.5 + 0.5) * canvas.height;
      indicator.style.display = 'block';
      indicator.style.left = sx + 'px';
      indicator.style.top = sy + 'px';
    } else {
      indicator.style.display = 'none';
    }

    requestAnimationFrame(draw);
  }
  requestAnimationFrame(draw);
})();
</script>
